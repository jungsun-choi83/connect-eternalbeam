# 프로덕션(또는 스테이징) 공개 오리진 — OAuth 리다이렉트·QR 등록 URL에 사용
PUBLIC_ORIGIN=https://connect.eternalbeam.com

# 리버스 프록시(Nginx, Cloudflare 등) 뒤에서 실행 시 Express가 X-Forwarded-* 를 신뢰
# TRUST_PROXY=1

# Google OAuth (선택)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Kakao OAuth (선택)
# KAKAO_REST_API_KEY=
# KAKAO_CLIENT_SECRET=

# 관리자 기기 등록 (선택)
# ADMIN_SECRET=

# 프론트만 다른 호스트에서 빌드할 때 API 베이스 (기본: 동일 오리진 = 빈 값)
# VITE_API_BASE=

# --- Supabase (프론트) — 대시보드 Project Settings → API 에서 복사
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Supabase (API 서버: Express) — connect_letters 저장·기기 GET 에 필요
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (서버에만, 절대 프론트/Vercel 노출 금지)
# 오렌지 파이 GET /api/connect/letters?device_id= 시 사용
# CONNECT_DEVICE_API_KEY=긴_무작위_문자열

# --- 로컬만: 결제 없이 구독 대시보드 테스트 (npm run dev 의 서버 스크립트에 이미 포함됨)
# CONNECT_DEV_SUBSCRIPTION=1

# 배포용 빌드 미리보기에서 개발 버튼 노출 (프론트)
# VITE_ENABLE_DEV_SUBSCRIPTION=true

# --- Toss Payments (프론트 결제창)
# 테스트 키 예시: test_ck_D5GePWvyJnrK0W0k6q8gLzN97Eoq
# VITE_TOSS_CLIENT_KEY=

# --- 감정 푸시 알림 (선택)
# OpenAI로 푸시 문구를 생성하려면 설정, 미설정 시 서버 템플릿 fallback 사용
# OPENAI_API_KEY=
# OPENAI_REPLY_MODEL=gpt-4o-mini
# OPENAI_PUSH_MODEL=gpt-4o-mini
# 실제 푸시 전송 시스템(Firebase/OneSignal/커스텀 워커) Webhook URL
# PUSH_DELIVERY_WEBHOOK=https://your-push-worker.example.com/push

# --- Vercel에서 할 일 (요약)
# 1) Add New → Project → 이 Git 저장소 연결, Root 그대로, Build: npm run build, Output: dist
# 2) Settings → Domains → connect.eternalbeam.com 추가 (DNS는 이미 CNAME으로 연결됨)
# 3) Settings → Environment Variables → 위 변수들 + PUBLIC_ORIGIN=https://connect.eternalbeam.com
# 4) Express API를 같은 프로젝트에 올리지 않는 경우: API 전용 호스트에 배포 후 VITE_API_BASE에 그 URL
